#!/usr/bin/env bash
# 𝚅𝚒𝚋𝚎𝚌𝚛𝚊𝚏𝚝𝚎𝚍. command deck
set -euo pipefail

_expand_home_path() {
  local raw="${1:-}"
  case "$raw" in
    [~]) printf '%s\n' "$HOME" ;;
    [~]/*) printf '%s/%s\n' "$HOME" "${raw:2}" ;;
    *) printf '%s\n' "$raw" ;;
  esac
}

crafted_home="$(_expand_home_path "${VIBECRAFTED_HOME:-$HOME/.vibecrafted}")"
crafted_skills="$crafted_home/skills"
crafted_tools="$crafted_home/tools/vibecrafted-current"

_bold='\033[1m'
_dim='\033[2m'
_copper='\033[38;5;173m'
_steel='\033[38;5;247m'
_green='\033[32m'
_yellow='\033[33m'
_cyan='\033[36m'
_red='\033[31m'
_reset='\033[0m'

_agents=(claude codex gemini)
_modes=(implement research review plan prompt observe)
_skills=(decorate delegate dou followup hydrate justdo marbles partner prune release research review scaffold workflow)

_script_repo_root() {
  local script_dir
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  cd "$script_dir/.." && pwd
}

_is_framework_source_root() {
  local candidate="${1:-}"
  [[ -n "$candidate" && -f "$candidate/VERSION" && -f "$candidate/scripts/vibecrafted" && -d "$candidate/skills" ]]
}

_repo_source_root() {
  local repo_root script_root
  repo_root="$(_repo_root)"
  if _is_framework_source_root "$repo_root"; then
    printf '%s\n' "$repo_root"
    return 0
  fi

  script_root="$(_script_repo_root)"
  if _is_framework_source_root "$script_root" && [[ "$script_root" != "$crafted_tools" ]]; then
    printf '%s\n' "$script_root"
    return 0
  fi

  return 1
}

_version() {
  local source_root repo_root vf
  repo_root="$(_script_repo_root)"
  source_root="$(_repo_source_root 2>/dev/null || true)"

  for vf in \
    "${source_root:+$source_root/VERSION}" \
    "$crafted_home/VERSION" \
    "$crafted_tools/VERSION" \
    "$repo_root/VERSION"; do
    [[ -f "$vf" ]] || continue
    cat "$vf"
    return 0
  done

  echo "?"
}

_repo_root() {
  git rev-parse --show-toplevel 2>/dev/null || pwd
}

_has_agent() {
  local candidate="${1:-}"
  [[ "$candidate" == "claude" || "$candidate" == "codex" || "$candidate" == "gemini" ]]
}

_has_mode() {
  local candidate="${1:-}"
  local mode
  for mode in "${_modes[@]}"; do
    [[ "$candidate" == "$mode" ]] && return 0
  done
  return 1
}

_has_skill() {
  local candidate="${1:-}"
  local skill
  for skill in "${_skills[@]}"; do
    [[ "$candidate" == "$skill" ]] && return 0
  done
  return 1
}

_skill_candidates() {
  local skill="$1"
  local runtime="${2:-}"
  local repo_source
  repo_source="$(_repo_source_root 2>/dev/null || true)"

  if [[ -n "$repo_source" ]]; then
    printf '%s\n' "$repo_source/skills/${skill}/SKILL.md"
  fi

  if [[ -n "$runtime" ]]; then
    printf '%s\n' "$HOME/.${runtime}/skills/${skill}/SKILL.md"
  fi

  printf '%s\n' \
    "$crafted_skills/${skill}/SKILL.md" \
    "$crafted_tools/skills/${skill}/SKILL.md" \
    "$HOME/.agents/skills/${skill}/SKILL.md"
}

_resolve_skill_path() {
  local skill="$1"
  local runtime="${2:-}"
  local candidate

  while IFS= read -r candidate; do
    [[ -r "$candidate" ]] || continue
    printf '%s\n' "$candidate"
    return 0
  done < <(_skill_candidates "$skill" "$runtime")

  printf '%b[error]%b Could not find %s.\n' "$_red" "$_reset" "$skill" >&2
  printf '  Expected one of:\n' >&2
  _skill_candidates "$skill" "$runtime" | sed 's/^/    - /' >&2
  return 1
}

_helper_candidates() {
  local repo_source repo_helper
  repo_source="$(_repo_source_root 2>/dev/null || true)"
  repo_helper="$(_script_repo_root)/skills/vc-agents/shell/vetcoders.sh"
  if [[ -n "$repo_source" ]]; then
    printf '%s\n' "$repo_source/skills/vc-agents/shell/vetcoders.sh"
  fi
  printf '%s\n' \
    "${XDG_CONFIG_HOME:-$HOME/.config}/vetcoders/vc-skills.sh" \
    "$crafted_skills/vc-agents/shell/vetcoders.sh" \
    "$crafted_tools/skills/vc-agents/shell/vetcoders.sh" \
    "$repo_helper"
}

_ensure_helpers_loaded() {
  local helper
  while IFS= read -r helper; do
    [[ -r "$helper" ]] || continue
    # shellcheck disable=SC1090
    source "$helper"
    return 0
  done < <(_helper_candidates)
  printf '%b[error]%b Could not find the 𝚅𝚒𝚋𝚎𝚌𝚛𝚊𝚏𝚝𝚎𝚍. helper layer.\n' "$_red" "$_reset" >&2
  printf '  Expected one of:\n' >&2
  _helper_candidates | sed 's/^/    - /' >&2
  return 1
}

_run_helper() {
  local helper="$1"
  shift
  if command -v "$helper" >/dev/null 2>&1; then
    "$helper" "$@"
    return 0
  fi
  printf '%b[error]%b Missing helper %s.\n' "$_red" "$_reset" "$helper" >&2
  return 1
}

cmd_help() {
  if [[ "${1:-}" == "--full" ]] || (( VIBECRAFTED_VERBOSE )); then
    cmd_help_full
    return
  fi
  local ver
  ver="$(_version)"
  printf '\n'
  printf '%b⚒  𝚅𝚒𝚋𝚎𝚌𝚛𝚊𝚏𝚝𝚎𝚍. %s%b\n' "$_bold$_copper" "$ver" "$_reset"
  printf '%b─────────────────────────────────────────%b\n' "$_steel" "$_reset"
  printf '  The Founders'"'"' Framework\n'
  printf '  A convergence-driven system for shipping software with AI agents.\n'
  printf '\n'
  printf '%bFront door:%b\n' "$_bold" "$_reset"
  printf '  %bvibecrafted help%b                      Show the command deck\n' "$_cyan" "$_reset"
  printf '  %bvibecrafted help --full%b               Full reference (all skills, modes, aliases)\n' "$_cyan" "$_reset"
  printf '  %bvibecrafted init%b [agent]              Start an interactive init session\n' "$_cyan" "$_reset"
  printf '  %bvibecrafted dashboard%b [layout]        Launch an optional repo-owned Zellij dashboard\n' "$_cyan" "$_reset"
  printf '  %bvibecrafted%b <skill> <agent> [flags]   Run a framework skill\n' "$_cyan" "$_reset"
  printf '  %bvibecrafted resume%b <agent> [flags]    Resume an existing agent session\n' "$_cyan" "$_reset"
  printf '  %bvibecrafted%b <agent> <mode> [args]     implement/research/review/plan/prompt/observe\n' "$_cyan" "$_reset"
  printf '  %bvibecrafted status%b                    Today'"'"'s agent activity\n' "$_cyan" "$_reset"
  printf '  %bvibecrafted doctor%b                    Verify installation health\n' "$_cyan" "$_reset"
  printf '  %bvibecrafted uninstall%b                 Reverse the install\n' "$_cyan" "$_reset"
  printf '\n'
  printf '%bExamples:%b\n' "$_bold" "$_reset"
  printf '  vibecrafted init claude\n'
  printf '  vibecrafted dashboard vc-marbles\n'
  printf '  vibecrafted workflow claude --prompt "Plan and implement auth"\n'
  printf '  vibecrafted justdo codex --prompt "Ship the feature"\n'
  printf '  vibecrafted codex implement .vibecrafted/plans/my-plan.md\n'
  printf '  vibecrafted codex observe --last\n'
  printf '  vibecrafted resume claude --session <id> --prompt "Continue"\n'
  printf '\n'
  printf '%bSkill flags (uniform contract):%b\n' "$_bold" "$_reset"
  printf '  -p, --prompt <text>            Inline prompt\n'
  printf '  -f, --file <path.md>           Input file as prompt context\n'
  printf '  --count <n>                    Marbles loop count (default: 3)\n'
  printf '  --depth <n>                    Marbles plan crawl depth (default: 3)\n'
  printf '  --session <id>                 Session ID for vibecrafted resume\n'
  printf '\n'
  printf '%bGlobal options:%b\n' "$_bold" "$_reset"
  printf '  --verbose                      Detailed output from all commands\n'
  printf '\n'
  printf '  %bvibecrafted help --full%b for the complete reference.\n' "$_dim" "$_reset"
  printf '\n'
}

cmd_help_full() {
  local ver
  ver="$(_version)"
  printf '\n'
  printf '%b⚒  𝚅𝚒𝚋𝚎𝚌𝚛𝚊𝚏𝚝𝚎𝚍. %s%b (Full Reference)\n' "$_bold$_copper" "$ver" "$_reset"
  printf '%b─────────────────────────────────────────%b\n' "$_steel" "$_reset"
  printf '  The Founders'"'"' Framework\n'
  printf '  A convergence-driven system for shipping software with AI agents.\n'
  printf '\n'
  printf '%b=== PIPELINE (canonical order) ===%b\n' "$_bold" "$_reset"
  printf '\n'
  printf '  %bscaffold%b   → Plan architecture from a vague idea\n' "$_copper" "$_reset"
  printf '  %binit%b       → Orient: history, eyes, verify\n' "$_copper" "$_reset"
  printf '  %bworkflow%b   → Examine → Research → Implement\n' "$_copper" "$_reset"
  printf '  %bfollowup%b   → Audit implementation gaps\n' "$_copper" "$_reset"
  printf '  %bmarbles%b    → Convergence loop (counterexample elimination)\n' "$_copper" "$_reset"
  printf '  %bdou%b        → Definition of Undone audit\n' "$_copper" "$_reset"
  printf '  %bdecorate%b   → Visual finishing and UX coherence\n' "$_copper" "$_reset"
  printf '  %bhydrate%b    → Packaging and go-to-market\n' "$_copper" "$_reset"
  printf '  %brelease%b    → Ship to production\n' "$_copper" "$_reset"
  printf '\n'
  printf '%b=== MODES (per agent) ===%b\n' "$_bold" "$_reset"
  printf '\n'
  printf '  %bvibecrafted <agent> implement%b <plan.md>   Execute a plan file\n' "$_cyan" "$_reset"
  printf '  %bvibecrafted <agent> research%b  <plan.md>   Research a topic\n' "$_cyan" "$_reset"
  printf '  %bvibecrafted <agent> review%b    <plan.md>   Review code or architecture\n' "$_cyan" "$_reset"
  printf '  %bvibecrafted <agent> plan%b      <plan.md>   Generate an implementation plan\n' "$_cyan" "$_reset"
  printf '  %bvibecrafted <agent> prompt%b    <plan.md>   Free-form prompt with context\n' "$_cyan" "$_reset"
  printf '  %bvibecrafted <agent> observe%b   --last      Check last agent report/transcript\n' "$_cyan" "$_reset"
  printf '\n'
  printf '%b=== OPERATOR SURFACE ===%b\n' "$_bold" "$_reset"
  printf '\n'
  printf '  %bvibecrafted dashboard%b [layout]        Launch repo-owned Zellij dashboard (%bvc-dashboard%b default)\n' "$_cyan" "$_reset" "$_bold" "$_reset"
  printf '  %bvibecrafted start%b [layout]            Alias for %bvibecrafted dashboard%b\n' "$_cyan" "$_reset" "$_cyan" "$_reset"
  printf '\n'
  printf '  Agents: %bclaude%b · %bcodex%b · %bgemini%b\n' "$_bold" "$_reset" "$_bold" "$_reset" "$_bold" "$_reset"
  printf '\n'
  printf '%b=== ADDITIONAL SKILLS ===%b\n' "$_bold" "$_reset"
  printf '\n'
  printf '  %bpartner%b    Collaborative debugging and architecture triage\n' "$_copper" "$_reset"
  printf '  %bjustdo%b     Autonomous end-to-end implementation\n' "$_copper" "$_reset"
  printf '  %bdelegate%b   In-session native subagent delegation\n' "$_copper" "$_reset"
  printf '  %bresearch%b   Triple-agent research (claude + codex + gemini)\n' "$_copper" "$_reset"
  printf '  %breview%b     Full PR review pipeline\n' "$_copper" "$_reset"
  printf '  %bprune%b      Runtime/publish cone extraction\n' "$_copper" "$_reset"
  printf '\n'
  printf '%b=== MANAGEMENT ===%b\n' "$_bold" "$_reset"
  printf '\n'
  printf '  %bvibecrafted help%b                      Compact command deck\n' "$_cyan" "$_reset"
  printf '  %bvibecrafted help --full%b               This full reference\n' "$_cyan" "$_reset"
  printf '  %bvibecrafted init%b [agent]              Interactive init session\n' "$_cyan" "$_reset"
  printf '  %bvibecrafted resume%b <agent> [flags]    Resume an existing agent session\n' "$_cyan" "$_reset"
  printf '  %bvibecrafted status%b                    Today'"'"'s agent activity\n' "$_cyan" "$_reset"
  printf '  %bvibecrafted doctor%b                    Installation health check\n' "$_cyan" "$_reset"
  printf '  %bvibecrafted version%b                   Print version\n' "$_cyan" "$_reset"
  printf '  %bvibecrafted uninstall%b                 Reverse the install\n' "$_cyan" "$_reset"
  printf '\n'
  printf '%b=== ALIASES ===%b\n' "$_bold" "$_reset"
  printf '\n'
  printf '  %bstats%b = status       %bcheck%b = doctor       %bremove%b = uninstall\n' "$_dim" "$_reset" "$_dim" "$_reset" "$_dim" "$_reset"
  printf '\n'
  printf '%b=== SKILL FLAGS (uniform contract) ===%b\n' "$_bold" "$_reset"
  printf '\n'
  printf '  -p, --prompt <text>            Inline prompt\n'
  printf '  -f, --file <path.md>           Input file as prompt context\n'
  printf '  --count <n>                    Marbles loop count (default: 3)\n'
  printf '  --depth <n>                    Marbles plan crawl depth (default: 3)\n'
  printf '  --session <id>                 Session ID for vibecrafted resume\n'
  printf '\n'
  printf '%b=== GLOBAL OPTIONS ===%b\n' "$_bold" "$_reset"
  printf '\n'
  printf '  --verbose                      Detailed output from all commands\n'
  printf '\n'
  printf '%b=== INFRASTRUCTURE ===%b\n' "$_bold" "$_reset"
  printf '\n'
  printf '  vibecrafted codex implement .vibecrafted/plans/my-plan.md\n'
  printf '  vibecrafted claude research .vibecrafted/plans/my-plan.md\n'
  printf '  vibecrafted gemini review .vibecrafted/plans/my-plan.md\n'
  printf '  vibecrafted codex observe --last\n'
  printf '  vibecrafted resume claude --session <id> --prompt "Continue the fix"\n'
  printf '\n'
  printf '%b=== EXAMPLES ===%b\n' "$_bold" "$_reset"
  printf '\n'
  printf '  vibecrafted init claude\n'
  printf '  vibecrafted dashboard vc-workflow\n'
  printf '  vibecrafted workflow claude --prompt "Plan and implement auth"\n'
  printf '  vibecrafted workflow claude --file /path/to/brief.md\n'
  printf '  vibecrafted marbles codex --count 3 --depth 3\n'
  printf '  vibecrafted justdo codex --prompt "Ship the feature"\n'
  printf '  vibecrafted dou claude\n'
  printf '  vibecrafted hydrate codex\n'
  printf '  vibecrafted release codex\n'
  printf '  vibecrafted prune codex\n'
  printf '\n'
}

cmd_start() {
  cmd_dashboard "$@"
}

cmd_init() {
  local agent="${1:-claude}"
  local init_prompt skill_path
  _has_agent "$agent" || {
    printf '%b[error]%b Unknown agent: %s\n' "$_red" "$_reset" "$agent" >&2
    return 1
  }

  case "$agent" in
    claude) command -v claude >/dev/null 2>&1 || return 1 ;;
    codex) command -v codex >/dev/null 2>&1 || return 1 ;;
    gemini) command -v gemini >/dev/null 2>&1 || return 1 ;;
  esac

  skill_path="$(_resolve_skill_path "vc-init" "$agent")" || return 1
  printf -v init_prompt "Use [\$vc-init](%s) on this repository and give me full operating context." "$skill_path"

  printf '%b⚒%b  Starting %b%s%b with vc-init...\n' "$_copper" "$_reset" "$_bold" "$agent" "$_reset"
  case "$agent" in
    claude) claude "$init_prompt" ;;
    codex) codex "$init_prompt" ;;
    gemini) gemini "$init_prompt" ;;
  esac
}

cmd_doctor() {
  local makefile="" repo_source=""
  repo_source="$(_repo_source_root 2>/dev/null || true)"
  for candidate in \
    "${repo_source:+$repo_source/Makefile}" \
    "$crafted_tools/Makefile" \
    "$(_repo_root)/Makefile"; do
    [[ -f "$candidate" ]] && makefile="$candidate" && break
  done
  [[ -n "$makefile" ]] || {
    printf '%b[error]%b Makefile not found. Is 𝚅𝚒𝚋𝚎𝚌𝚛𝚊𝚏𝚝𝚎𝚍. installed?\n' "$_red" "$_reset" >&2
    return 1
  }
  make -C "$(dirname "$makefile")" doctor
}

cmd_dashboard() {
  _ensure_helpers_loaded || return 1
  _run_helper vc-dashboard "$@"
}

cmd_stats() {
  local today_dir artifacts_dir
  today_dir="$(date +%Y_%m%d)"
  artifacts_dir="$crafted_home/artifacts"
  printf '\n%b⚒  𝚅𝚒𝚋𝚎𝚌𝚛𝚊𝚏𝚝𝚎𝚍. Stats — %s%b\n' "$_bold$_copper" "$(date +%Y-%m-%d)" "$_reset"
  printf '%b─────────────────────────────────────────%b\n' "$_steel" "$_reset"
  if [[ ! -d "$artifacts_dir" ]]; then
    printf '  No artifacts found yet.\n\n'
    return 0
  fi
  find "$artifacts_dir" -path "*${today_dir}*" -name "*.meta.json" -type f | sort -r | sed -n '1,8p' | sed 's#^#  #'
  printf '\n'
}

cmd_uninstall() {
  local makefile="" repo_source=""
  repo_source="$(_repo_source_root 2>/dev/null || true)"
  for candidate in \
    "${repo_source:+$repo_source/Makefile}" \
    "$crafted_tools/Makefile" \
    "$(_repo_root)/Makefile"; do
    [[ -f "$candidate" ]] && makefile="$candidate" && break
  done
  [[ -n "$makefile" ]] || {
    printf '%b[error]%b Makefile not found.\n' "$_red" "$_reset" >&2
    return 1
  }
  make -C "$(dirname "$makefile")" uninstall
}

cmd_agents() {
  printf '\n'
  printf '%bVibeCrafted agent helpers%b\n' "$_bold" "$_reset"
  printf '  Use %bvibecrafted <agent> implement|research|review|plan%b for plan-based helper flows.\n' "$_cyan" "$_reset"
  printf '  Example: vibecrafted codex implement .vibecrafted/plans/my-plan.md\n'
  printf '\n'
}

cmd_resume() {
  local agent="${1:-}"
  [[ -n "$agent" ]] || {
    printf '%b[error]%b Usage: vibecrafted resume <claude|codex|gemini> --session <session_id> [--prompt <text>] [--file <path>]\n' "$_red" "$_reset" >&2
    return 1
  }
  shift || true
  _has_agent "$agent" || {
    printf '%b[error]%b Unknown agent: %s\n' "$_red" "$_reset" "$agent" >&2
    return 1
  }
  _ensure_helpers_loaded || return 1
  _run_helper vc-resume "$agent" "$@"
}

run_mode() {
  local agent="$1"
  local mode="$2"
  shift 2
  if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    printf '%b⚒%b  %b%s %s%b\n\n' "$_copper" "$_reset" "$_bold" "$agent" "$mode" "$_reset"
    case "$mode" in
      implement) printf '  Execute a plan file with the agent.\n  Usage: vibecrafted %s implement <plan.md>\n' "$agent" ;;
      research)  printf '  Research a topic using the agent.\n  Usage: vibecrafted %s research <plan.md>\n' "$agent" ;;
      review)    printf '  Review code or architecture.\n  Usage: vibecrafted %s review <plan.md>\n' "$agent" ;;
      plan)      printf '  Generate an implementation plan.\n  Usage: vibecrafted %s plan <plan.md>\n' "$agent" ;;
      prompt)    printf '  Free-form prompt with plan context.\n  Usage: vibecrafted %s prompt <plan.md>\n' "$agent" ;;
      observe)   printf '  Check the last agent report or transcript.\n  Usage: vibecrafted %s observe --last\n' "$agent" ;;
    esac
    printf '\n'
    return 0
  fi
  _ensure_helpers_loaded || return 1
  _run_helper "${agent}-${mode}" "$@"
}

run_skill() {
  local skill="$1"
  local agent="${2:-}"
  shift 2 || true

  if [[ "$skill" == "init" ]]; then
    cmd_init "$agent" "$@"
    return
  fi

  if [[ "$skill" == "agents" ]]; then
    cmd_agents "$@"
    return
  fi

  if [[ "$agent" == "dashboard" ]]; then
    cmd_dashboard "vc-${skill}" "$@"
    return
  fi

  _has_agent "$agent" || {
    printf '%b[error]%b Usage: vibecrafted %s <claude|codex|gemini> [args]\n' "$_red" "$_reset" "$skill" >&2
    return 1
  }

  _ensure_helpers_loaded || return 1
  _run_helper "${agent}-skill-${skill}" "$@"
}

run_wrapper() {
  local wrapper="$1"
  shift
  if [[ "$wrapper" == "vc-help" ]]; then
    cmd_help
    return
  fi
  if [[ "$wrapper" == "vc-start" ]]; then
    cmd_start "$@"
    return
  fi
  if [[ "$wrapper" == "vc-init" ]]; then
    cmd_init "$@"
    return
  fi
  if [[ "$wrapper" == "vc-resume" ]]; then
    cmd_resume "$@"
    return
  fi
  if [[ "$wrapper" == "vc-agents" ]]; then
    cmd_agents "$@"
    return
  fi
  local skill="${wrapper#vc-}"
  [[ "$skill" != "implement" ]] || skill="justdo"
  _has_skill "$skill" || {
    printf '%b[error]%b Unknown wrapper: %s\n' "$_red" "$_reset" "$wrapper" >&2
    return 1
  }
  run_skill "$skill" "$@"
}

cmd_unknown() {
  local attempted="$1"
  printf '\n'
  printf '%b⚒%b  "%s" is not in the command deck.\n' "$_copper" "$_reset" "$attempted"
  printf '  Try %bvibecrafted help%b for the current surface.\n\n' "$_cyan" "$_reset"
}

main() {
  local invoked cmd
  invoked="$(basename "$0")"

  # Global flags — strip before dispatch
  export VIBECRAFTED_VERBOSE="${VIBECRAFTED_VERBOSE:-0}"
  local filtered=()
  for _arg in "$@"; do
    case "$_arg" in
      --verbose) VIBECRAFTED_VERBOSE=1 ;;
      *) filtered+=("$_arg") ;;
    esac
  done
  set -- ${filtered[@]+"${filtered[@]}"}

  if [[ "$invoked" != "vibecrafted" ]]; then
    run_wrapper "$invoked" "$@"
    return
  fi

  cmd="${1:-help}"
  shift || true

  case "$cmd" in
    help|-h|--help) cmd_help "$@" ;;
    start) cmd_start "$@" ;;
    init) cmd_init "$@" ;;
    resume) cmd_resume "$@" ;;
    doctor|check) cmd_doctor ;;
    dashboard|mc|mission-control) cmd_dashboard "$@" ;;
    stats|status) cmd_stats ;;
    uninstall|remove) cmd_uninstall ;;
    version|--version|-v) printf 'vibecrafted %s\n' "$(_version)" ;;
    agents) cmd_agents "$@" ;;
    claude|codex|gemini)
      local mode="${1:-}"
      [[ -n "$mode" ]] || {
        printf '%b[error]%b Usage: vibecrafted %s <mode> [args]\n' "$_red" "$_reset" "$cmd" >&2
        return 1
      }
      shift || true
      _has_mode "$mode" || {
        printf '%b[error]%b Unknown mode: %s\n' "$_red" "$_reset" "$mode" >&2
        return 1
      }
      run_mode "$cmd" "$mode" "$@"
      ;;
    implement) run_skill "justdo" "$@" ;;
    decorate|delegate|dou|followup|hydrate|justdo|marbles|partner|prune|release|research|review|scaffold|workflow)
      run_skill "$cmd" "$@"
      ;;
    *)
      cmd_unknown "$cmd"
      return 1
      ;;
  esac
}

main "$@"
