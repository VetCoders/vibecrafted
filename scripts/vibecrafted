  printf '\n'
  printf '%bвљ’%b  %bstart%b\n' "$_copper" "$_reset" "$_bold" "$_reset"
  printf '%bв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ%b\n' "$_steel" "$_reset"
  printf '  Start the operator Zellij session.\n'
  printf '\n'
  printf '%bUsage:%b\n' "$_bold" "$_reset"
  printf '  vibecrafted start\n'
  printf '  vc-start\n'
  printf '  vc-start resume\n'
  printf '\n'
  printf '%bExamples:%b\n' "$_bold" "$_reset"
  printf '  vibecrafted start\n'
  printf '  vc-start resume\n'
  printf '\n'
}

cmd_dashboard_help() {
  printf '\n'
  printf '%bвљ’%b  %bdashboard%b\n' "$_copper" "$_reset" "$_bold" "$_reset"
  printf '%bв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ%b\n' "$_steel" "$_reset"
