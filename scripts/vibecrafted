#!/usr/bin/env bash
# рќљ…рќљ’рќљ‹рќљЋрќљЊрќљ›рќљЉрќљЏрќљќрќљЋрќљЌ. command deck
set -euo pipefail

_expand_home_path() {
  local raw="${1:-}"
  case "$raw" in
    [~]) printf '%s\n' "$HOME/" ;;
    [~]/*) printf '%s/%s\n' "$HOME/" "${raw:2}" ;;
    *) printf '%s\n' "$raw" ;;
  esac
}

crafted_home="$(_expand_home_path "${VIBECRAFTED_HOME:-$HOME/.vibecrafted}")"
crafted_skills="$crafted_home/skills"
crafted_tools="$crafted_home/tools/vibecrafted-current"

_bold='\033[1m'
_dim='\033[2m'
_copper='\033[38;5;173m'
_steel='\033[38;5;247m'
_green='\033[32m'
_yellow='\033[33m'
_cyan='\033[36m'
_red='\033[31m'
_reset='\033[0m'

_agents=(claude codex gemini)
_modes=(implement research review plan prompt observe)
_skills=(decorate delegate dou followup hydrate justdo marbles partner prune release research review scaffold workflow)

_script_repo_root() {
  local script_dir
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  cd "$script_dir/.." && pwd
}

_is_framework_source_root() {
  local candidate="${1:-}"
  [[ -n "$candidate" && -f "$candidate/VERSION" && -f "$candidate/scripts/vibecrafted" && -d "$candidate/skills" ]]
}

_repo_source_root() {
  local repo_root script_root
  repo_root="$(_repo_root)"
  if _is_framework_source_root "$repo_root"; then
    printf '%s\n' "$repo_root"
    return 0
  fi

  script_root="$(_script_repo_root)"
  if _is_framework_source_root "$script_root" && [[ "$script_root" != "$crafted_tools" ]]; then
    printf '%s\n' "$script_root"
    return 0
  fi

  return 1
}

_version() {
  local source_root repo_root vf
  repo_root="$(_script_repo_root)"
  source_root="$(_repo_source_root 2>/dev/null || true)"

  for vf in \
    "${source_root:+$source_root/VERSION}" \
    "$crafted_home/VERSION" \
    "$crafted_tools/VERSION" \
    "$repo_root/VERSION"; do
    [[ -f "$vf" ]] || continue
    cat "$vf"
    return 0
  done

  echo "?"
}

_repo_root() {
  git rev-parse --show-toplevel 2>/dev/null || pwd
}

_has_agent() {
  local candidate="${1:-}"
  [[ "$candidate" == "claude" || "$candidate" == "codex" || "$candidate" == "gemini" ]]
}

_has_mode() {
  local candidate="${1:-}"
  local mode
  for mode in "${_modes[@]}"; do
    [[ "$candidate" == "$mode" ]] && return 0
  done
  return 1
}

_has_skill() {
  local candidate="${1:-}"
  local skill
  for skill in "${_skills[@]}"; do
    [[ "$candidate" == "$skill" ]] && return 0
  done
  return 1
}

_skill_candidates() {
  local skill="$1"
  local runtime="${2:-}"
  local repo_source
  repo_source="$(_repo_source_root 2>/dev/null || true)"

  if [[ -n "$repo_source" ]]; then
    printf '%s\n' "$repo_source/skills/${skill}/SKILL.md"
  fi

  if [[ -n "$runtime" ]]; then
    printf '%s\n' "$HOME/.${runtime}/skills/${skill}/SKILL.md"
  fi

  printf '%s\n' \
    "$crafted_skills/${skill}/SKILL.md" \
    "$crafted_tools/skills/${skill}/SKILL.md" \
    "$HOME/.agents/skills/${skill}/SKILL.md"
}

_resolve_skill_path() {
  local skill="$1"
  local runtime="${2:-}"
  local candidate

  while IFS= read -r candidate; do
    [[ -r "$candidate" ]] || continue
    printf '%s\n' "$candidate"
    return 0
  done < <(_skill_candidates "$skill" "$runtime")

  printf '%b[error]%b Could not find %s.\n' "$_red" "$_reset" "$skill" >&2
  printf '  Expected one of:\n' >&2
  _skill_candidates "$skill" "$runtime" | sed 's/^/    - /' >&2
  return 1
}

_helper_candidates() {
  local repo_source repo_helper
  repo_source="$(_repo_source_root 2>/dev/null || true)"
  repo_helper="$(_script_repo_root)/skills/vc-agents/shell/vetcoders.sh"
  if [[ -n "$repo_source" ]]; then
    printf '%s\n' "$repo_source/skills/vc-agents/shell/vetcoders.sh"
  fi
  printf '%s\n' \
    "${XDG_CONFIG_HOME:-$HOME/.config}/vetcoders/vc-skills.sh" \
    "$crafted_skills/vc-agents/shell/vetcoders.sh" \
    "$crafted_tools/skills/vc-agents/shell/vetcoders.sh" \
    "$repo_helper"
}

_ensure_helpers_loaded() {
  local helper
  while IFS= read -r helper; do
    [[ -r "$helper" ]] || continue
    # shellcheck disable=SC1090
    source "$helper"
    return 0
  done < <(_helper_candidates)
  printf '%b[error]%b Could not find the рќљ…рќљ’рќљ‹рќљЋрќљЊрќљ›рќљЉрќљЏрќљќрќљЋрќљЌ. helper layer.\n' "$_red" "$_reset" >&2
  printf '  Expected one of:\n' >&2
  _helper_candidates | sed 's/^/    - /' >&2
  return 1
}

_run_helper() {
  local helper="$1"
  shift
  if command -v "$helper" >/dev/null 2>&1; then
    "$helper" "$@"
    return 0
  fi
  printf '%b[error]%b Missing helper %s.\n' "$_red" "$_reset" "$helper" >&2
  return 1
}

_is_help_flag() {
  local candidate="${1:-}"
  [[ "$candidate" == "--help" || "$candidate" == "-h" || "$candidate" == "help" ]]
}

_skill_summary() {
  case "$1" in
    decorate) printf 'Visual finishing and UX coherence pass.\n' ;;
    delegate) printf 'Native in-session subagent delegation.\n' ;;
    dou) printf 'Definition of Undone audit across the product surface.\n' ;;
    followup) printf 'Post-implementation audit for gaps, regressions, and next moves.\n' ;;
    hydrate) printf 'Packaging and go-to-market hydration.\n' ;;
    justdo) printf 'Autonomous end-to-end implementation when the thing simply needs to ship.\n' ;;
    marbles) printf 'Counterexample loop that keeps fixing what is still wrong until the surface is clean.\n' ;;
    partner) printf 'Collaborative debugging, architecture triage, or full ownership mode.\n' ;;
    prune) printf 'Runtime and publish-cone cleanup with hard cuts and proof.\n' ;;
    release) printf 'Release mechanics, deployment reality, and ship-readiness work.\n' ;;
    research) printf 'Triple-agent research pass for ground truth before implementation.\n' ;;
    review) printf 'Full review pipeline with findings-first output.\n' ;;
    scaffold) printf 'Founder-first architecture planning from a vague idea.\n' ;;
    workflow) printf 'Examine -> Research -> Implement pipeline.\n' ;;
    *) printf 'Framework skill.\n' ;;
  esac
}

_print_common_skill_flags() {
  printf '%bCommon flags:%b\n' "$_bold" "$_reset"
  printf '  -p, --prompt <text>            Inline prompt\n'
  printf '  -f, --file <path.md>           Input file as prompt context\n'
}

_print_skill_specific_flags() {
  case "$1" in
    marbles)
      printf '\n%bSkill-specific flags:%b\n' "$_bold" "$_reset"
      printf '  --count <n>                    Marbles loop count (default: 3)\n'
      printf '  --depth <n>                    Marbles plan crawl depth (default: 3)\n'
      ;;
    resume)
      printf '\n%bResume flags:%b\n' "$_bold" "$_reset"
      printf '  --session <id>                 Session ID to resume\n'
      printf '  -p, --prompt <text>            Continue with extra prompt text\n'
      printf '  -f, --file <path.md>           Continue with prompt context from file\n'
      ;;
  esac
}

cmd_skill_help() {
  local skill="$1"
  local agent="${2:-<claude|codex|gemini>}"
  local wrapper="vc-$skill"

  printf '\n'
  printf '%bвљ’%b  %b%s%b\n' "$_copper" "$_reset" "$_bold" "$skill" "$_reset"
  printf '%bв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ%b\n' "$_steel" "$_reset"
  printf '  %s' "$(_skill_summary "$skill")"
  printf '\n'
  printf '%bUsage:%b\n' "$_bold" "$_reset"
  printf '  vibecrafted %s %s [flags]\n' "$skill" "$agent"
  printf '  %s %s [flags]\n' "$wrapper" "$agent"
  if [[ "$skill" == "justdo" ]]; then
    printf '  Alias: vibecrafted implement <agent> [flags] / vc-implement <agent> [flags]\n'
  fi
  printf '\n'
  printf '%bExamples:%b\n' "$_bold" "$_reset"
  case "$skill" in
    justdo)
      printf '  vibecrafted justdo codex --prompt "Ship the feature"\n'
      printf '  vibecrafted implement claude --file /path/to/brief.md\n'
      ;;
    marbles)
      printf '  vibecrafted marbles codex --count 3 --depth 3\n'
      printf '  vc-marbles claude --prompt "Loop until clean"\n'
      ;;
    followup)
      printf '  vibecrafted followup codex --prompt "Audit this implementation"\n'
      printf '  vc-followup claude --file /path/to/brief.md\n'
      ;;
    workflow)
      printf '  vibecrafted workflow claude --prompt "Plan and implement auth"\n'
      printf '  vc-workflow codex --file /path/to/brief.md\n'
      ;;
    review)
      printf '  vibecrafted review codex --prompt "Review this branch"\n'
      printf '  vc-review claude --file /path/to/pr-brief.md\n'
      ;;
    research)
      printf '  vibecrafted research gemini --prompt "Research the API surface"\n'
      printf '  vc-research codex --file /path/to/question-set.md\n'
      ;;
    *)
      printf '  vibecrafted %s codex --prompt "Run %s on this repository"\n' "$skill" "$skill"
      printf '  %s claude --file /path/to/brief.md\n' "$wrapper"
      ;;
  esac
  printf '\n'
  _print_common_skill_flags
  _print_skill_specific_flags "$skill"
  printf '\n'
}

cmd_agent_help() {
  local agent="$1"
  printf '\n'
  printf '%bвљ’%b  %b%s%b\n' "$_copper" "$_reset" "$_bold" "$agent" "$_reset"
  printf '%bв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ%b\n' "$_steel" "$_reset"
  printf '  Plan-based helper modes for %s.\n' "$agent"
  printf '\n'
  printf '%bUsage:%b\n' "$_bold" "$_reset"
  printf '  vibecrafted %s <implement|research|review|plan|prompt|observe> [args]\n' "$agent"
  printf '\n'
  printf '%bModes:%b\n' "$_bold" "$_reset"
  printf '  implement <plan.md>            Execute a plan file\n'
  printf '  research  <plan.md>            Research a topic or plan file\n'
  printf '  review    <plan.md>            Review code or architecture\n'
  printf '  plan      <plan.md>            Generate an implementation plan\n'
  printf '  prompt    <plan.md>            Free-form prompt with plan context\n'
  printf '  observe   --last               Check the last report or transcript\n'
  printf '\n'
  printf '%bExamples:%b\n' "$_bold" "$_reset"
  printf '  vibecrafted %s implement .vibecrafted/plans/my-plan.md\n' "$agent"
  printf '  vibecrafted %s research .vibecrafted/plans/my-plan.md\n' "$agent"
  printf '  vibecrafted %s observe --last\n' "$agent"
  printf '\n'
}

